{
	"plugins": [
		"@trivago/prettier-plugin-sort-imports",
		"prettier-plugin-brace-style",
		"prettier-plugin-packagejson"
	],
	"braceStyle": "allman",
	"useTabs": true,
	"tabWidth": 4,
	"semi": true,
	"singleQuote": true,
	"trailingComma": "all",
	"bracketSpacing": true,
	"arrowParens": "always",
	"printWidth": 80,
	"importOrder": [
		"<BUILTIN_MODULES>",
		"<THIRD_PARTY_MODULES>",
		"^@core/(.*)$",
		"^@server/(.*)$",
		"^@ui/(.*)$",
		"^[./]"
	],
	"importOrderSeparation": true,
	"importOrderSortSpecifiers": true,
	"importOrderSortByLength": "asc",
	"importOrderSideEffects": false,
	"packageSortOrder": ["name", "version", "description", "main"]
}
